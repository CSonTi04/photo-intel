# VLM Wrapper — runs on GPU node alongside Ollama
# Lightweight image — only needs FastAPI + httpx + Pillow

FROM python:3.11-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    libgl1-mesa-glx \
    libglib2.0-0 \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Minimal dependencies for the wrapper
RUN pip install --no-cache-dir \
    fastapi>=0.115.0 \
    uvicorn[standard]>=0.30.0 \
    httpx>=0.27.0 \
    pillow>=10.3.0 \
    pydantic>=2.7.0 \
    pydantic-settings>=2.3.0 \
    structlog>=24.1.0 \
    python-multipart>=0.0.9

COPY src/vlm_wrapper/ ./src/vlm_wrapper/

EXPOSE 8100

HEALTHCHECK --interval=15s --timeout=5s --retries=3 \
    CMD python -c "import httpx; r=httpx.get('http://localhost:8100/ready-for-vlm'); print(r.json())" || exit 1

CMD ["uvicorn", "src.vlm_wrapper.app:app", "--host", "0.0.0.0", "--port", "8100"]
